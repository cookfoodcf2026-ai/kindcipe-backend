# ─── Required ────────────────────────────────────────────────────────────────

# Supabase PostgreSQL connection string
# Get from: Supabase Dashboard → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# JWT secret for session cookies (generate a random 32+ char string)
# Generate: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-here

# ─── Google OAuth (Social Login) ─────────────────────────────────────────────

# Google OAuth Web Client ID
# Get from: Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=690207937492-7hfs5hkksd5heo78kcfmq294f19rgp6d.apps.googleusercontent.com

# Google OAuth Web Client Secret
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Cloudflare R2 Storage ────────────────────────────────────────────────────

# Get from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=kindcipe-storage
# Public URL (if bucket is public): https://pub-xxx.r2.dev
R2_PUBLIC_URL=

# ─── Alibaba Cloud DashScope (Qwen LLM) ──────────────────────────────────────

# Get DashScope API Key from: https://modelstudio.console.alibabacloud.com → API Key
# Singapore endpoint: https://ws-{workspaceId}.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
# International default: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=sk-your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ─── Optional ─────────────────────────────────────────────────────────────────

# Allowed CORS origins (comma-separated, leave empty to allow all)
ALLOWED_ORIGINS=

# YouTube API Key (for recipe import from YouTube)
YOUTUBE_API_KEY=

# RapidAPI Key (for price checking)
RAPIDAPI_KEY=

# App ID (optional, defaults to "kindcipe")
APP_ID=kindcipe
